# URL base do OLANCE (sem barra no final)
OLANCE_URL=https://olance.app

# Mesmo segredo configurado em CRON_SECRET no OLANCE
CRON_SECRET=troque-por-um-segredo-forte

# Quantos imóveis enriquecer por execução (detalhes raspados página a página)
BATCH_SIZE=300

# Headless: true em servidor/CI, false para depurar localmente vendo o browser
HEADLESS=true

# Delays (segundos) entre requisições de detalhe — evita rate-limit/blacklist
DETAIL_MIN_DELAY=2.0
DETAIL_MAX_DELAY=4.0
